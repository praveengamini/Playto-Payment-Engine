DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/playto
APP_ENV=development
SECRET_KEY=replace-with-a-long-random-secret

# CORS (comma-separated, no trailing slash)
# Add your deployed frontend origin(s) here.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://playto-payment-engine.netlify.app





CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=rpc://




IDEMPOTENCY_TTL_SECONDS=86400
PAYOUT_SUCCESS_RATE=0.70
PAYOUT_FAIL_RATE=0.20
PAYOUT_PROCESSING_TIMEOUT_SECONDS=30
PAYOUT_MAX_RETRIES=3

